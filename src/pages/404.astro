---
import BaseLayout from '@/layouts/base-layout.astro'
import { siteConfig } from '@/config/site-config'
---

<BaseLayout title={`Not Found | ${siteConfig.name}`}>
  <div class="glass-panel rounded-2xl px-8 py-16 text-center">
    <h1 class="mb-2 text-4xl font-bold text-slate-900">404</h1>
    <p class="mb-6 text-slate-500">This page could not be found.</p>
    <a href="/" class="text-sm font-medium text-blue-600 hover:text-blue-800">
      Back to Home
    </a>
  </div>
</BaseLayout>
