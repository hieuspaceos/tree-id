---
import BaseLayout from '@/layouts/base-layout.astro'
import { getAllCategories } from '@/lib/content-helpers'

const categories = await getAllCategories()
---

<BaseLayout title="Categories" description="Browse content by category">
  <section class="mb-8">
    <h1 class="mb-6 text-2xl font-bold tracking-tight text-slate-900">Categories</h1>

    {categories.length === 0 ? (
      <div class="glass-panel rounded-2xl px-8 py-12 text-center">
        <p class="text-slate-400">No categories yet.</p>
      </div>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {categories.map((cat) => (
          <a href={`/categories/${cat.id}`} class="glass-card block p-5">
            <div class="mb-2 flex items-center gap-2">
              <span
                class="inline-block h-3 w-3 rounded-full"
                style={`background-color: ${cat.data.color || '#6366f1'}`}
              />
              <h2 class="text-lg font-semibold text-slate-900">{cat.data.name}</h2>
            </div>
            {cat.data.description && (
              <p class="text-sm leading-relaxed text-slate-500">{cat.data.description}</p>
            )}
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
