---
/**
 * Login page — email/password + optional Google OAuth via Better Auth.
 * Redirects to /dashboard after successful sign-in.
 */
import BaseLayout from '@/layouts/base-layout.astro'

export const prerender = false

const { getAuth } = await import('@/lib/auth')
const auth = getAuth()
const session = await auth.api.getSession({ headers: Astro.request.headers })
if (session?.session) {
  return Astro.redirect('/dashboard')
}

const rawRedirect = Astro.url.searchParams.get('redirect') || '/dashboard'
const redirect = rawRedirect.startsWith('/') && !rawRedirect.startsWith('//') ? rawRedirect : '/dashboard'
const siteUrl = import.meta.env.PUBLIC_SITE_URL || process.env.PUBLIC_SITE_URL || 'http://localhost:4321'
const hasGoogle = !!(import.meta.env.GOOGLE_CLIENT_ID || process.env.GOOGLE_CLIENT_ID)
---

<BaseLayout title="Sign In">
  <div style="max-width: 400px; margin: 4rem auto; padding: 2rem">
    <h1 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem; text-align: center">Sign In</h1>
    <p style="color: #64748b; margin-bottom: 2rem; text-align: center">Sign in to create your landing page</p>

    <!-- Email + Password form -->
    <form id="auth-form" style="display: flex; flex-direction: column; gap: 0.75rem">
      <input id="name" type="text" placeholder="Name" style="padding: 0.6rem 0.75rem; border: 1px solid #d1d5db; border-radius: 8px; font-size: 0.9rem; display: none" />
      <input id="email" type="email" placeholder="Email" required style="padding: 0.6rem 0.75rem; border: 1px solid #d1d5db; border-radius: 8px; font-size: 0.9rem" />
      <input id="password" type="password" placeholder="Password" required minlength="8" style="padding: 0.6rem 0.75rem; border: 1px solid #d1d5db; border-radius: 8px; font-size: 0.9rem" />
      <button id="submit-btn" type="submit" style="padding: 0.65rem; background: #1e293b; color: white; border: none; border-radius: 8px; font-size: 0.9rem; font-weight: 600; cursor: pointer">
        Sign In
      </button>
      <p id="error-msg" style="color: #dc2626; font-size: 0.8rem; text-align: center; display: none; margin: 0"></p>
      <button id="toggle-mode" type="button" style="background: none; border: none; color: #6366f1; font-size: 0.8rem; cursor: pointer; padding: 0.25rem">
        Don't have an account? Sign up
      </button>
    </form>

    {hasGoogle && (
      <>
        <div style="display: flex; align-items: center; gap: 0.75rem; margin: 1.25rem 0">
          <hr style="flex: 1; border: none; border-top: 1px solid #e2e8f0" />
          <span style="font-size: 0.8rem; color: #94a3b8">or</span>
          <hr style="flex: 1; border: none; border-top: 1px solid #e2e8f0" />
        </div>
        <button
          id="google-login"
          style="width: 100%; display: inline-flex; align-items: center; justify-content: center; gap: 0.75rem; padding: 0.65rem; border: 1px solid #d1d5db; border-radius: 8px; background: white; cursor: pointer; font-size: 0.9rem; font-weight: 500"
        >
          <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Continue with Google
        </button>
      </>
    )}

    <p style="margin-top: 1.5rem; font-size: 0.8rem; color: #94a3b8; text-align: center">
      Free account — no credit card required.
    </p>
  </div>

  <script is:inline define:vars={{ siteUrl, redirect, hasGoogle }}>
    let isSignUp = false
    const form = document.getElementById('auth-form')
    const nameField = document.getElementById('name')
    const submitBtn = document.getElementById('submit-btn')
    const toggleBtn = document.getElementById('toggle-mode')
    const errorMsg = document.getElementById('error-msg')

    toggleBtn?.addEventListener('click', () => {
      isSignUp = !isSignUp
      nameField.style.display = isSignUp ? 'block' : 'none'
      submitBtn.textContent = isSignUp ? 'Sign Up' : 'Sign In'
      toggleBtn.textContent = isSignUp ? 'Already have an account? Sign in' : "Don't have an account? Sign up"
      errorMsg.style.display = 'none'
    })

    form?.addEventListener('submit', async (e) => {
      e.preventDefault()
      errorMsg.style.display = 'none'
      submitBtn.disabled = true
      submitBtn.textContent = 'Loading...'

      const email = document.getElementById('email').value
      const password = document.getElementById('password').value
      const name = nameField.value || email.split('@')[0]

      try {
        const endpoint = isSignUp ? '/api/auth/sign-up/email' : '/api/auth/sign-in/email'
        const body = isSignUp ? { email, password, name } : { email, password }
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        })
        if (res.ok) {
          window.location.href = redirect
        } else {
          const data = await res.json().catch(() => ({}))
          errorMsg.textContent = data.message || (isSignUp ? 'Sign up failed. Try different email.' : 'Invalid email or password.')
          errorMsg.style.display = 'block'
        }
      } catch {
        errorMsg.textContent = 'Network error. Please try again.'
        errorMsg.style.display = 'block'
      }
      submitBtn.disabled = false
      submitBtn.textContent = isSignUp ? 'Sign Up' : 'Sign In'
    })

    if (hasGoogle) {
      document.getElementById('google-login')?.addEventListener('click', () => {
        window.location.href = `${siteUrl}/api/auth/sign-in/social?provider=google&callbackURL=${encodeURIComponent(redirect)}`
      })
    }
  </script>
</BaseLayout>
