---
export const prerender = true

/**
 * Homepage — renders the 'home' landing page from content/landing-pages/home.yaml.
 * Uses the same landing renderer pipeline as [landing].astro.
 */
import { getCollection } from 'astro:content'
import LandingLayout from '@/layouts/landing-layout.astro'
import LandingSectionRenderer from '@/components/landing/landing-section-renderer.astro'
import type { LandingSection, LandingDesign, LandingSeo } from '@/lib/landing/landing-types'
import { websiteJsonLd, safeJsonLd } from '@/lib/seo/json-ld'

const pages = await getCollection('landingPages')
const page = pages.find(p => p.id === 'home')

// Fallback: if no home.yaml exists, show a simple message
if (!page) {
  return Astro.redirect('/404')
}

const sections = page.data.sections as unknown as LandingSection[]
const pageData = page.data as Record<string, unknown>
const design = pageData.design as LandingDesign | undefined
const scopedCss = pageData.scopedCss as Array<{ selector: string; css: string }> | undefined
const seo = pageData.seo as LandingSeo | undefined

const hasNav = sections.some(s => s.type === 'nav')
const hasFooter = sections.some(s => s.type === 'footer')
---

<LandingLayout
  title={page.data.title}
  description={page.data.description}
  hideNav={hasNav}
  hideFooter={hasFooter}
  design={design}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={safeJsonLd(websiteJsonLd())} />
  </Fragment>
  {seo?.ogImage && <meta slot="head" property="og:image" content={seo.ogImage} />}
  {seo?.keywords && <meta slot="head" name="keywords" content={seo.keywords} />}
  <LandingSectionRenderer sections={sections} pageTitle={page.data.title} scopedCss={scopedCss} />
</LandingLayout>
