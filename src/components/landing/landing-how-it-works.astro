---
import type { HowItWorksData } from '@/lib/landing/landing-types'

interface Props extends HowItWorksData {}
const { heading, subheading, items } = Astro.props
---

<section class="landing-section">
  {heading && <h2 class="mb-2 text-center text-3xl font-bold text-slate-900">{heading}</h2>}
  {subheading && <p class="mx-auto mb-8 max-w-2xl text-center text-slate-500">{subheading}</p>}
  <div class="landing-grid-3">
    {items.map((step, i) => (
      <div class="glass-card p-6 text-center">
        <span class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-full bg-green-500/10 text-lg font-bold text-green-600">
          {step.number ?? i + 1}
        </span>
        <h3 class="mb-2 text-lg font-semibold text-slate-900">{step.title}</h3>
        <p class="text-sm text-slate-500">{step.description}</p>
      </div>
    ))}
  </div>
</section>
