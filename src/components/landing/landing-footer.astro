---
/**
 * Landing page footer section — minimal footer with optional text and links.
 */
import type { FooterData } from '@/lib/landing/landing-types'

interface Props extends FooterData {
  pageTitle?: string
}

const { text, links = [], pageTitle } = Astro.props
const year = new Date().getFullYear()
---

<footer class="landing-section border-t border-slate-200/50 py-8 text-center text-sm text-slate-400">
  {links.length > 0 && (
    <div class="mb-4 flex justify-center gap-4">
      {links.map(link => (
        <a href={link.href} class="text-slate-500 hover:text-slate-700 transition-colors">
          {link.label}
        </a>
      ))}
    </div>
  )}
  <p>{text || `© ${year} ${pageTitle || ''}`}</p>
</footer>
