---
/**
 * Features section with 6 layout variants:
 * - grid (default): card grid layout
 * - list: vertical list with icon left, text right
 * - alternating: zigzag rows (image/icon alternates sides)
 * - masonry: CSS columns layout, cards with varying heights
 * - icon-strip: horizontal scrollable icon bar, icon above label (→ landing-features-icon-strip.astro)
 * - bento: CSS grid, first item spans 2 rows (→ landing-features-bento.astro)
 */
import type { FeaturesData } from '@/lib/landing/landing-types'
import IconStrip from './landing-features-icon-strip.astro'
import Bento from './landing-features-bento.astro'

interface Props extends FeaturesData {}
const { heading, subheading, items = [], columns = 3, variant = 'grid' } = Astro.props
const gridClass = `landing-grid-${columns}` as const
/** Auto-detect if items have images — switches to image-card mode */
const hasImages = items.some(item => item.image)
---

{/* Grid: default card grid */}
{variant === 'grid' && (
  <section class="landing-section">
    {heading && <h2 class="mb-2 text-center text-3xl font-bold">{heading}</h2>}
    {subheading && <p class="mx-auto mb-8 max-w-2xl text-center" style="color: var(--lp-text-muted)">{subheading}</p>}
    <div class={gridClass}>
      {items.map((item) => {
        /* Image-overlay card: photo with title at bottom (like travel/portfolio cards) */
        const imageOverlayCard = (
          <div class="lp-card-hover" style="position: relative; border-radius: 12px; overflow: hidden; aspect-ratio: 4/3">
            <img src={item.image} alt={item.title} style="width: 100%; height: 100%; object-fit: cover" loading="lazy" />
            <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.1) 50%, transparent 100%)"></div>
            <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 1rem 1.25rem">
              <h3 style="color: #fff; font-weight: 600; font-size: 0.95rem; text-shadow: 0 1px 3px rgba(0,0,0,0.4)">{item.title}</h3>
              {item.description && <p style="color: rgba(255,255,255,0.8); font-size: 0.8rem; margin-top: 0.25rem">{item.description}</p>}
            </div>
          </div>
        )
        /* Standard icon/text card */
        const standardCard = (
          <div class="lp-card-hover" style="background: color-mix(in srgb, var(--lp-primary) 5%, var(--lp-surface)); border-radius: var(--lp-radius); border: 1px solid color-mix(in srgb, var(--lp-primary) 8%, transparent); overflow: hidden; padding: 1.5rem">
            {item.icon && (item.icon.startsWith('http') ? <img src={item.icon} alt={item.title} class="mb-3 h-10 w-10 object-contain" /> : <div class="lp-icon-bg mb-3">{item.icon}</div>)}
            <h3 class="text-lg mb-2 font-semibold">{item.title}</h3>
            {item.description && <p class="text-sm mt-1" style="color: var(--lp-text-muted); line-height: 1.7">{item.description}</p>}
            {item.price && (
              <div style="margin-top: 1.25rem; padding-top: 1.25rem; border-top: 1px solid color-mix(in srgb, var(--lp-text) 10%, transparent); display: flex; align-items: center; justify-content: space-between">
                <span style="font-size: 0.9375rem; color: var(--lp-accent, var(--lp-primary)); font-weight: 500">{item.price}</span>
                {item.priceType && (
                  <span style="font-size: 0.75rem; color: var(--lp-text-muted); background: color-mix(in srgb, var(--lp-text) 5%, transparent); padding: 0.25rem 0.625rem; border-radius: 100px">{item.priceType}</span>
                )}
              </div>
            )}
          </div>
        )
        const card = item.image ? imageOverlayCard : standardCard
        return item.url ? <a href={item.url} style="text-decoration: none; color: inherit">{card}</a> : card
      })}
    </div>
  </section>
)}

{/* List: vertical list, icon left + text right */}
{variant === 'list' && (
  <section class="landing-section">
    {heading && <h2 class="mb-2 text-center text-3xl font-bold">{heading}</h2>}
    {subheading && <p class="mx-auto mb-8 max-w-2xl text-center" style="color: var(--lp-text-muted)">{subheading}</p>}
    <div class="mx-auto max-w-3xl" style="display: flex; flex-direction: column; gap: 1rem">
      {items.map((item) => (
        <div style="display: flex; align-items: flex-start; gap: 1.25rem; padding: 1.25rem; background: color-mix(in srgb, var(--lp-primary) 5%, var(--lp-surface)); border-radius: var(--lp-radius)">
          {item.icon && (
            item.icon.startsWith('http') ? <img src={item.icon} alt={item.title} style="width: 2.5rem; height: 2.5rem; object-fit: contain; flex-shrink: 0" /> : <span style="font-size: 1.75rem; flex-shrink: 0; width: 2.5rem; text-align: center">{item.icon}</span>
          )}
          {!item.icon && (
            <span style="width: 2.5rem; height: 2.5rem; flex-shrink: 0; border-radius: 50%; background: color-mix(in srgb, var(--lp-primary) 15%, transparent); display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; color: var(--lp-primary)">✓</span>
          )}
          <div>
            <h3 class="mb-1 text-base font-semibold">{item.title}</h3>
            <p class="text-sm" style="color: var(--lp-text-muted)">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
)}

{/* Alternating: zigzag rows */}
{variant === 'alternating' && (
  <section class="landing-section">
    {heading && <h2 class="mb-2 text-center text-3xl font-bold">{heading}</h2>}
    {subheading && <p class="mx-auto mb-8 max-w-2xl text-center" style="color: var(--lp-text-muted)">{subheading}</p>}
    <div style="display: flex; flex-direction: column; gap: 2.5rem">
      {items.map((item, i) => (
        <div style={`display: flex; align-items: center; gap: 2rem; flex-wrap: wrap; flex-direction: ${i % 2 === 1 ? 'row-reverse' : 'row'}`}>
          <div style="flex: 1; min-width: 220px; display: flex; align-items: center; justify-content: center; font-size: 4rem; padding: 2rem; background: color-mix(in srgb, var(--lp-primary) 8%, var(--lp-surface)); border-radius: var(--lp-radius)">
            {item.icon || '✦'}
          </div>
          <div style="flex: 2; min-width: 220px">
            <h3 class="mb-2 text-xl font-bold">{item.title}</h3>
            <p style="color: var(--lp-text-muted); line-height: 1.7">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
)}

{/* Masonry: CSS columns, cards with varying heights */}
{variant === 'masonry' && (
  <section class="landing-section">
    {heading && <h2 class="mb-2 text-center text-3xl font-bold">{heading}</h2>}
    {subheading && <p class="mx-auto mb-8 max-w-2xl text-center" style="color: var(--lp-text-muted)">{subheading}</p>}
    <div style="columns: 1; gap: 1rem; column-gap: 1rem" class="lp-masonry-cols">
      {items.map((item) => (
        <div
          class="lp-card-hover"
          style="break-inside: avoid; margin-bottom: 1rem; padding: 1.5rem; background: color-mix(in srgb, var(--lp-primary) 5%, var(--lp-surface)); border-radius: var(--lp-radius); border: 1px solid color-mix(in srgb, var(--lp-primary) 8%, transparent)"
        >
          {item.image && <img src={item.image} alt={item.title} style="width: 100%; border-radius: 8px; margin-bottom: 0.875rem; object-fit: cover" loading="lazy" />}
          {item.icon && !item.image && (
            item.icon.startsWith('http')
              ? <img src={item.icon} alt="" class="mb-3 h-9 w-9 object-contain" />
              : <div class="lp-icon-bg mb-3">{item.icon}</div>
          )}
          <h3 class="font-semibold text-base mb-1">{item.title}</h3>
          {item.description && <p class="text-sm" style="color: var(--lp-text-muted); line-height: 1.65">{item.description}</p>}
        </div>
      ))}
    </div>
  </section>
)}

{/* Icon-strip: horizontal scrollable icon bar — delegated */}
{variant === 'icon-strip' && (
  <IconStrip heading={heading} subheading={subheading} items={items} columns={columns} variant={variant} />
)}

{/* Bento: CSS grid first-item 2-row span — delegated */}
{variant === 'bento' && (
  <Bento heading={heading} subheading={subheading} items={items} columns={columns} variant={variant} />
)}

<style>
  @media (min-width: 640px) {
    .lp-masonry-cols { columns: 2 !important; }
  }
  @media (min-width: 1024px) {
    .lp-masonry-cols { columns: 3 !important; }
  }
</style>
