---
import type { ImageData } from '@/lib/landing/landing-types'

interface Props extends ImageData {}
const { src, alt, caption, fullWidth } = Astro.props
---

<section class="landing-section">
  <div class={fullWidth ? 'w-full' : 'mx-auto max-w-3xl'}>
    <img
      src={src}
      alt={alt || ''}
      class={`rounded-xl ${fullWidth ? 'w-full' : 'w-full object-cover'}`}
      loading="lazy"
      decoding="async"
    />
    {caption && <p class="mt-3 text-center text-sm text-slate-500">{caption}</p>}
  </div>
</section>
