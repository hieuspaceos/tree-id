---
import type { FaqData } from '@/lib/landing/landing-types'

interface Props extends FaqData {}
const { heading, items } = Astro.props
---

<section class="landing-section">
  {heading && <h2 class="mb-8 text-center text-3xl font-bold text-slate-900">{heading}</h2>}
  <div class="mx-auto max-w-2xl space-y-3">
    {items.map((faq) => (
      <details class="glass-card rounded-xl">
        <summary class="cursor-pointer px-6 py-4 text-sm font-semibold text-slate-900 select-none">
          {faq.question}
        </summary>
        <p class="px-6 pb-4 text-sm text-slate-500">{faq.answer}</p>
      </details>
    ))}
  </div>
</section>
