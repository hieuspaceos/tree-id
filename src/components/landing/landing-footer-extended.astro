---
/**
 * Footer extended variants:
 * - mega: 4-5 column layout with link groups, newsletter input, social icons
 * - centered-social: centered text + large social icon row + copyright
 *
 * Used by landing-footer.astro when variant === 'mega' or 'centered-social'.
 */
import type { FooterData } from '@/lib/landing/landing-types'

interface Props extends FooterData {
  pageTitle?: string
  copyright: string
}

const { text, links = [], columns = [], socialLinks = [], newsletter, variant, copyright } = Astro.props
---

{/* Mega: 4-5 columns + newsletter + social */}
{variant === 'mega' && (
  <footer class="landing-footer py-14 text-sm">
    <div class="mx-auto max-w-6xl px-6">
      <div class="lp-footer-grid" style={`--lp-footer-cols: ${Math.max(columns.length, 1) + (newsletter ? 1 : 0)}; margin-bottom: 3rem`}>
        {columns.map(col => (
          <div>
            <p class="mb-3 text-xs font-semibold uppercase tracking-wider" style="color: var(--lp-text)">{col.heading}</p>
            <ul style="display:flex;flex-direction:column;gap:0.5rem">
              {(col.links ?? []).map(l => (
                <li><a href={l.href} class="transition-colors hover:opacity-70" style="color:var(--lp-text-muted)">{l.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
        {newsletter && (
          <div>
            <p class="mb-3 text-xs font-semibold uppercase tracking-wider" style="color: var(--lp-text)">{newsletter.heading || 'Newsletter'}</p>
            <form action={newsletter.action || '#'} method="post" class="lp-mega-newsletter" onsubmit="event.preventDefault()">
              <input type="email" name="email" placeholder={newsletter.placeholder || 'your@email.com'} required class="lp-mega-email-input" />
              <button type="submit" class="lp-mega-email-btn">{newsletter.buttonText || 'Subscribe'}</button>
            </form>
            {socialLinks.length > 0 && (
              <div style="display:flex;gap:0.75rem;margin-top:1.25rem;flex-wrap:wrap">
                {socialLinks.map(sl => (
                  <a href={sl.url} target="_blank" rel="noopener noreferrer" aria-label={sl.label || sl.icon}
                    class="transition-opacity hover:opacity-70" style="font-size:1.3rem;color:var(--lp-text-muted)">
                    {sl.icon?.startsWith('http') ? <img src={sl.icon} alt={sl.label || ''} style="height:20px;width:20px;object-fit:contain" /> : sl.icon}
                  </a>
                ))}
              </div>
            )}
          </div>
        )}
      </div>
      <div style="border-top:1px solid color-mix(in srgb, var(--lp-text) 10%, transparent);padding-top:1.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem">
        <p style="color:var(--lp-text-muted)">{copyright}</p>
        <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
          {links.map(l => <a href={l.href} class="transition-colors hover:opacity-70" style="color:var(--lp-text-muted)">{l.label}</a>)}
          {!newsletter && socialLinks.map(sl => (
            <a href={sl.url} target="_blank" rel="noopener noreferrer" aria-label={sl.label || sl.icon}
              class="transition-opacity hover:opacity-70" style="font-size:1.2rem;color:var(--lp-text-muted)">
              {sl.icon?.startsWith('http') ? <img src={sl.icon} alt={sl.label || ''} style="height:18px;width:18px;object-fit:contain" /> : sl.icon}
            </a>
          ))}
        </div>
      </div>
    </div>
  </footer>
)}

{/* Centered-social: centered text + large social icons + copyright */}
{variant === 'centered-social' && (
  <footer class="landing-footer py-12 text-center">
    {text && <p class="mb-2 text-base font-medium" style="color: var(--lp-text)">{text}</p>}
    {links.length > 0 && (
      <div class="mb-5 flex justify-center flex-wrap gap-4 text-sm">
        {links.map(l => <a href={l.href} class="transition-colors hover:opacity-70" style="color:var(--lp-text-muted)">{l.label}</a>)}
      </div>
    )}
    {socialLinks.length > 0 && (
      <div class="mb-6 flex justify-center gap-4 flex-wrap">
        {socialLinks.map(sl => (
          <a href={sl.url} target="_blank" rel="noopener noreferrer" aria-label={sl.label || sl.icon}
            class="lp-cs-social-btn">
            {sl.icon?.startsWith('http')
              ? <img src={sl.icon} alt={sl.label || ''} style="height:24px;width:24px;object-fit:contain" />
              : <span style="font-size:1.6rem">{sl.icon}</span>
            }
          </a>
        ))}
      </div>
    )}
    <p class="text-xs" style="color:var(--lp-text-muted)">{copyright}</p>
  </footer>
)}

<style>
  .lp-mega-newsletter {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .lp-mega-email-input {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--lp-text) 15%, transparent);
    background: color-mix(in srgb, var(--lp-text) 4%, transparent);
    color: var(--lp-text);
    font-size: 0.85rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .lp-mega-email-input:focus { border-color: var(--lp-primary); }
  .lp-mega-email-input::placeholder { color: var(--lp-text-muted); }

  .lp-mega-email-btn {
    padding: 0.5rem 1rem;
    background: var(--lp-primary);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .lp-mega-email-btn:hover { opacity: 0.85; }

  .lp-cs-social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--lp-text) 6%, transparent);
    transition: background 0.2s, transform 0.2s;
    text-decoration: none;
  }
  .lp-cs-social-btn:hover {
    background: color-mix(in srgb, var(--lp-primary) 12%, transparent);
    transform: translateY(-2px);
  }
</style>
